# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Flight API (AviationStack, FlightAware, ADS-B Exchange, etc.)
FLIGHT_API_KEY=your-flight-api-key
FLIGHT_API_BASE_URL=https://api.aviationstack.com/v1

# Provider: "aviationstack" or "example" (mock data for local dev)
FLIGHT_PROVIDER=aviationstack

# Ingestion
POLL_INTERVAL_SECONDS=60
MIA_IATA_CODE=MIA
MIA_ICAO_CODE=KMIA

# Weather (Open-Meteo is free, no key required)
WEATHER_ENABLED=true
WEATHER_PROVIDER=openmeteo
WEATHER_POLL_INTERVAL_SECONDS=300

# ML / Predictions
PREDICTIONS_ENABLED=true
ANOMALY_DETECTION_ENABLED=true

# Optional: Sentry
SENTRY_DSN=
